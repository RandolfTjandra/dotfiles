[user]
    name = Randolf Tjandra
    email = randolftjandra@gmail.com

[includeIf "hostname:d4i-Tjandra"]
    path = ~/.config/gitconfig/environments/dinari

[pull]
  rebase = true

[include]
    path = ~/.config/gitconfig/aliases/common

[log]
  date = relative

[core]
  whitespace=fix,-indent-with-non-tab,trailing-space,cr-at-eol
  excludesfile = ~/.gitignore

[difftool "sourcetree"]
  cmd = opendiff \"$LOCAL\" \"$REMOTE\"
  path =

[mergetool "sourcetree"]
  cmd = /Applications/SourceTree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
  trustExitCode = true

[log]
  date = relative

[core]
  ; pager = less -FRSMX
  whitespace=fix,-indent-with-non-tab,trailing-space,cr-at-eol
  excludesfile = ~/.gitignore
  ; hooksPath = ~/.git-hooks
  ; diff-so-fancy
  pager="diff-so-fancy | less --tabs=4 -RF"
[interactive]
  diffFilter="diff-so-fancy --patch"


[url "ssh://git@github.com/"]
  insteadOf = https://github.com/

[commit]
  template = ~/.gitmessage
	gpgsign = false

[init]
  templatedir = ~/.git-templates
	defaultBranch = main

[core]
  excludesfile = ~/.gitignore

[url "git@github.com:"]
  insteadOf = https://github.com/



[difftool "sourcetree"]
  cmd = opendiff \"$LOCAL\" \"$REMOTE\"
  path =
[mergetool "sourcetree"]
  cmd = /Applications/SourceTree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
  trustExitCode = true

[log]
  date = relative

 ; You can set the color to any of the following values: normal, black,
 ; red, green, yellow, blue, magenta, cyan, or white. If you want an
 ; attribute like bold in the previous example, you can choose from bold,
 ; dim, ul (underline), blink, and reverse (swap foreground and background).
[color]
  ui = true
  pager = true
  log = true

[color "interactive"]
  prompt = blue bold
  error = red bold
  header = cyan bold
  help = green
  comment = magenta dim

[color "diff"]
  plain = white
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold
  whitespace = red blink

[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[core]
  pager = less -FRSX
  whitespace=fix,-indent-with-non-tab,trailing-space,cr-at-eol
  excludesfile = ~/.gitignore

[url "ssh://git@github.com/"]
  insteadOf = https://github.com/

[url "git@github.com:"]
  insteadOf = https://github.com/
